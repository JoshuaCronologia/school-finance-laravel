                "database": "accounting",
                "username": "root",
                "password": ""
            },
            "inventory": {
                "host": "127.0.0.1",
                "port": 3306,
                "database": "inventory",
                "username": "root",
                "password": ""
            },
            "branches": [
                {
                    "id": 1,
                    "name": "Main Branch",
