{
    "version": 2,
    "framework": null,
    "buildCommand": "npm install && npm run build",
    "installCommand": "npm install",
    "outputDirectory": "public",
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.2"
        }
    },
    "routes": [
        {
            "src": "/build/assets/(.*\\.(css|js|png|jpg|gif|svg|ico|woff|woff2|ttf|eot))",
            "dest": "/public/build/assets/$1",
            "headers": {
                "Cache-Control": "public, max-age=31536000, immutable"
            }
        },
        {
            "src": "/build/(.*)",
            "dest": "/public/build/$1"
        },
        {
            "src": "/favicon.ico",
            "dest": "/public/favicon.ico"
        },
        {
            "src": "/robots.txt",
            "dest": "/public/robots.txt"
        },
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "APP_KEY": "base64:ho1UcpdzhGq11KgZytDkmNEkU7LVEZUT90ASKcWxV1Q=",
        "APP_URL": "https://school-finance-laravel.vercel.app",
        "APP_CONFIG_CACHE": "/tmp/config.php",
        "APP_EVENTS_CACHE": "/tmp/events.php",
        "APP_PACKAGES_CACHE": "/tmp/packages.php",
        "APP_ROUTES_CACHE": "/tmp/routes.php",
        "APP_SERVICES_CACHE": "/tmp/services.php",
        "VIEW_COMPILED_PATH": "/tmp/views",
        "CACHE_STORE": "file",
        "CACHE_PATH": "/tmp/cache",
        "LOG_CHANNEL": "stderr",
        "SESSION_DRIVER": "cookie",
        "DB_CONNECTION": "pgsql",
        "DB_HOST": "aws-1-ap-southeast-2.pooler.supabase.com",
        "DB_PORT": "6543",
        "DB_DATABASE": "postgres",
        "DB_USERNAME": "postgres.mwwyssirtluulmwohquy",
        "DB_PASSWORD": "Joshua_Orange_apps",
        "DB_SSLMODE": "require"
    }
}
